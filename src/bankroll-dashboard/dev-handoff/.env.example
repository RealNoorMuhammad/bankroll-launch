# ── $BANKROLL distributor config ──────────────────────────────
# Copy to .env on the cron machine. NEVER commit this file.

RPC_URL=            # Robinhood Chain RPC endpoint
PRIVATE_KEY=        # distributor wallet key — dedicated wallet, gas + tax only
TOKEN=              # BANKROLL contract address (after deploy)
BATCH_SENDER=       # BatchSender contract address (after deploy)
EXPLORER_API=       # e.g. https://<chain-explorer-domain>/api/v2

EXCLUDE=            # comma-separated: pool address, locker, CEX wallets
MIN_PAYOUT=100      # min tokens per wallet per run; dust rolls to next day
BATCH_SIZE=200      # recipients per payout transaction

TG_BOT_TOKEN=       # optional — public audit channel bot
TG_CHAT_ID=         # optional — audit channel id
